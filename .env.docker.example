# ============================================================================
# CONFIGURAÇÃO DE BANCO DE DADOS EXTERNO
# ============================================================================

# Tipo de banco de dados: mysql ou postgres
DB_TYPE=mysql

# Opção 1: Componentes individuais (descomente para usar)
DB_HOST=localhost
DB_PORT=3306
DB_USER=crm_user
DB_PASSWORD=senha_segura
DB_NAME=crm_waha

# Opção 2: String de conexão completa (descomente para usar)
# DB_URL=mysql://usuario:senha@localhost:3306/crm_waha
# DB_URL=postgresql://usuario:senha@localhost:5432/crm_waha

# ============================================================================
# CONFIGURAÇÃO MANUS OAUTH
# ============================================================================

# ID da aplicação OAuth Manus
VITE_APP_ID=seu_app_id_aqui

# URLs de OAuth
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://app.manus.im

# Secret JWT para sessões
JWT_SECRET=sua_secret_jwt_aqui

# ============================================================================
# CONFIGURAÇÃO WAHA (WHATSAPP)
# ============================================================================

# URL da instância WAHA
WAHA_API_URL=http://localhost:3001

# Chave de API do WAHA (opcional)
WAHA_API_KEY=sua_chave_waha_aqui

# ============================================================================
# CONFIGURAÇÃO DE IA
# ============================================================================

# OpenAI
OPENAI_API_KEY=sk-...

# Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIzaSy...

# ============================================================================
# CONFIGURAÇÃO MANUS BUILT-IN APIs
# ============================================================================

# URL da API Manus
BUILT_IN_FORGE_API_URL=https://api.manus.im

# Chave de API do servidor
BUILT_IN_FORGE_API_KEY=sua_chave_servidor_aqui

# URL e chave para frontend
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=sua_chave_frontend_aqui

# ============================================================================
# CONFIGURAÇÃO DO PROPRIETÁRIO
# ============================================================================

# Nome do proprietário
OWNER_NAME=Seu Nome

# ID OpenID do proprietário (obtido do Manus)
OWNER_OPEN_ID=seu_openid_aqui

# ============================================================================
# CONFIGURAÇÃO DE ANALYTICS
# ============================================================================

# Endpoint de analytics
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im

# ID do website para analytics
VITE_ANALYTICS_WEBSITE_ID=seu_website_id_aqui

# ============================================================================
# CONFIGURAÇÃO DA APLICAÇÃO
# ============================================================================

# Título da aplicação
VITE_APP_TITLE=CRM Omnichannel WAHA

# Logo da aplicação (URL)
VITE_APP_LOGO=https://seu-dominio.com/logo.png

# ============================================================================
# EXEMPLOS DE STRINGS DE CONEXÃO
# ============================================================================

# MySQL Local
# DB_URL=mysql://root:password@localhost:3306/crm_waha

# MySQL Remoto
# DB_URL=mysql://crm_user:senha@db.example.com:3306/crm_waha

# PostgreSQL Local
# DB_URL=postgresql://postgres:password@localhost:5432/crm_waha

# PostgreSQL Remoto
# DB_URL=postgresql://crm_user:senha@db.example.com:5432/crm_waha

# AWS RDS MySQL
# DB_URL=mysql://admin:senha@crm-db.xxxxx.rds.amazonaws.com:3306/crm_waha

# AWS RDS PostgreSQL
# DB_URL=postgresql://postgres:senha@crm-db.xxxxx.rds.amazonaws.com:5432/crm_waha

# Google Cloud SQL MySQL
# DB_URL=mysql://root:senha@35.184.123.45:3306/crm_waha

# Google Cloud SQL PostgreSQL
# DB_URL=postgresql://postgres:senha@35.184.123.45:5432/crm_waha

# TiDB Cloud
# DB_URL=mysql://usuario:senha@tidb-host.tidbcloud.com:4000/crm_waha
